# # ==========================
# # Sphinx 文档编译产物（核心）
# # ==========================
# # 默认编译输出目录（执行 make html 生成的文件）
# build/
# # 自定义输出目录（根据你的配置修改）
# # _build/
# # 自动生成的文档目录（极少用）
# generated/

# # ==========================
# # Sphinx 缓存/临时文件
# # ==========================
# # 文档编译缓存
# .doctrees/
# # 编辑器/系统临时文件
# *.tmp
# *.swp
# *.swo
# *~

# # ==========================
# # Python 通用忽略（Sphinx 基于 Python）
# # ==========================
# # Python 字节码
# __pycache__/
# *.py[cod]
# *$py.class
# # 虚拟环境（如果放在项目内）
# venv/
# .env/
# .venv/
# env/
# # Python 依赖安装缓存
# *.egg-info/
# dist/
# .eggs/

# # ==========================
# # 系统/编辑器忽略文件
# # ==========================
# # macOS
# .DS_Store
# # Windows
# Thumbs.db
# Desktop.ini
# # VS Code
# .vscode/
# # PyCharm
# .idea/